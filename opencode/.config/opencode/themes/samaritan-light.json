{
  "$schema": "https://opencode.ai/theme.json",
  "defs": {
    "white": "#ffffff",
    "offWhite": "#f5f5f5",
    "fogLight": "#e8e8e8",
    "fogMid": "#d3d3d3",
    "grayLight": "#b0b0b0",
    "gray": "#717171",
    "grayDark": "#444444",
    "charcoal": "#1a1a1a",
    "black": "#0a0a0a",
    "void": "#000000",
    "red": "#dd0000",
    "redBright": "#ff0000",
    "redDeep": "#990000",
    "redFaint": "#fff0f0"
  },
  "theme": {
    "primary": { "dark": "red", "light": "red" },
    "secondary": { "dark": "gray", "light": "gray" },
    "accent": { "dark": "red", "light": "red" },
    "error": { "dark": "redBright", "light": "redBright" },
    "warning": { "dark": "redDeep", "light": "redDeep" },
    "success": { "dark": "redDeep", "light": "redDeep" },
    "info": { "dark": "gray", "light": "gray" },
    "text": { "dark": "void", "light": "void" },
    "textMuted": { "dark": "gray", "light": "gray" },
    "background": { "dark": "white", "light": "white" },
    "backgroundPanel": { "dark": "offWhite", "light": "offWhite" },
    "backgroundElement": { "dark": "fogLight", "light": "fogLight" },
    "border": { "dark": "fogMid", "light": "fogMid" },
    "borderActive": { "dark": "red", "light": "red" },
    "borderSubtle": { "dark": "fogLight", "light": "fogLight" },
    "diffAdded": { "dark": "grayDark", "light": "grayDark" },
    "diffRemoved": { "dark": "red", "light": "red" },
    "diffContext": { "dark": "gray", "light": "gray" },
    "diffHunkHeader": { "dark": "grayDark", "light": "grayDark" },
    "diffHighlightAdded": { "dark": "void", "light": "void" },
    "diffHighlightRemoved": { "dark": "redBright", "light": "redBright" },
    "diffAddedBg": { "dark": "#e8f5e8", "light": "#e8f5e8" },
    "diffRemovedBg": { "dark": "redFaint", "light": "redFaint" },
    "diffContextBg": { "dark": "white", "light": "white" },
    "diffLineNumber": { "dark": "grayLight", "light": "grayLight" },
    "diffAddedLineNumberBg": { "dark": "#e8f5e8", "light": "#e8f5e8" },
    "diffRemovedLineNumberBg": { "dark": "redFaint", "light": "redFaint" },
    "markdownText": { "dark": "void", "light": "void" },
    "markdownHeading": { "dark": "red", "light": "red" },
    "markdownLink": { "dark": "grayDark", "light": "grayDark" },
    "markdownLinkText": { "dark": "void", "light": "void" },
    "markdownCode": { "dark": "charcoal", "light": "charcoal" },
    "markdownBlockQuote": { "dark": "gray", "light": "gray" },
    "markdownEmph": { "dark": "grayDark", "light": "grayDark" },
    "markdownStrong": { "dark": "void", "light": "void" },
    "markdownHorizontalRule": { "dark": "fogMid", "light": "fogMid" },
    "markdownListItem": { "dark": "black", "light": "black" },
    "markdownListEnumeration": { "dark": "red", "light": "red" },
    "markdownImage": { "dark": "gray", "light": "gray" },
    "markdownImageText": { "dark": "grayDark", "light": "grayDark" },
    "markdownCodeBlock": { "dark": "charcoal", "light": "charcoal" },
    "syntaxComment": { "dark": "grayLight", "light": "grayLight" },
    "syntaxKeyword": { "dark": "red", "light": "red" },
    "syntaxFunction": { "dark": "void", "light": "void" },
    "syntaxVariable": { "dark": "black", "light": "black" },
    "syntaxString": { "dark": "grayDark", "light": "grayDark" },
    "syntaxNumber": { "dark": "redDeep", "light": "redDeep" },
    "syntaxType": { "dark": "gray", "light": "gray" },
    "syntaxOperator": { "dark": "red", "light": "red" },
    "syntaxPunctuation": { "dark": "grayLight", "light": "grayLight" }
  }
}
