{
  "$schema": "https://opencode.ai/theme.json",
  "defs": {
    "void": "#000000",
    "surface": "#0a0a0a",
    "panel": "#111111",
    "element": "#1a1a1a",
    "grayDark": "#444444",
    "gray": "#717171",
    "grayLight": "#9a9a9a",
    "grayBright": "#bcbcbc",
    "white": "#e8e8e8",
    "whitePure": "#ffffff",
    "red": "#ff0000",
    "redDim": "#cc0000",
    "redDeep": "#860000",
    "redFaint": "#330000"
  },
  "theme": {
    "primary": { "dark": "red", "light": "red" },
    "secondary": { "dark": "grayLight", "light": "gray" },
    "accent": { "dark": "red", "light": "redDim" },
    "error": { "dark": "red", "light": "red" },
    "warning": { "dark": "redDim", "light": "redDim" },
    "success": { "dark": "redDim", "light": "redDim" },
    "info": { "dark": "grayLight", "light": "gray" },
    "text": { "dark": "white", "light": "void" },
    "textMuted": { "dark": "gray", "light": "grayDark" },
    "background": { "dark": "void", "light": "whitePure" },
    "backgroundPanel": { "dark": "surface", "light": "grayBright" },
    "backgroundElement": { "dark": "element", "light": "grayLight" },
    "border": { "dark": "grayDark", "light": "grayLight" },
    "borderActive": { "dark": "red", "light": "red" },
    "borderSubtle": { "dark": "#222222", "light": "grayBright" },
    "diffAdded": { "dark": "grayBright", "light": "grayDark" },
    "diffRemoved": { "dark": "red", "light": "redDim" },
    "diffContext": { "dark": "gray", "light": "gray" },
    "diffHunkHeader": { "dark": "grayLight", "light": "grayDark" },
    "diffHighlightAdded": { "dark": "whitePure", "light": "void" },
    "diffHighlightRemoved": { "dark": "red", "light": "redDim" },
    "diffAddedBg": { "dark": "#0d1a0d", "light": "grayBright" },
    "diffRemovedBg": { "dark": "redFaint", "light": "#ffe0e0" },
    "diffContextBg": { "dark": "void", "light": "whitePure" },
    "diffLineNumber": { "dark": "grayDark", "light": "grayLight" },
    "diffAddedLineNumberBg": { "dark": "#0d1a0d", "light": "grayBright" },
    "diffRemovedLineNumberBg": { "dark": "redFaint", "light": "#ffe0e0" },
    "markdownText": { "dark": "white", "light": "void" },
    "markdownHeading": { "dark": "red", "light": "redDim" },
    "markdownLink": { "dark": "grayBright", "light": "grayDark" },
    "markdownLinkText": { "dark": "whitePure", "light": "void" },
    "markdownCode": { "dark": "grayBright", "light": "grayDark" },
    "markdownBlockQuote": { "dark": "gray", "light": "gray" },
    "markdownEmph": { "dark": "grayBright", "light": "grayDark" },
    "markdownStrong": { "dark": "whitePure", "light": "void" },
    "markdownHorizontalRule": { "dark": "grayDark", "light": "grayLight" },
    "markdownListItem": { "dark": "white", "light": "void" },
    "markdownListEnumeration": { "dark": "red", "light": "redDim" },
    "markdownImage": { "dark": "gray", "light": "gray" },
    "markdownImageText": { "dark": "grayLight", "light": "grayDark" },
    "markdownCodeBlock": { "dark": "grayBright", "light": "grayDark" },
    "syntaxComment": { "dark": "grayDark", "light": "grayLight" },
    "syntaxKeyword": { "dark": "red", "light": "redDim" },
    "syntaxFunction": { "dark": "whitePure", "light": "void" },
    "syntaxVariable": { "dark": "white", "light": "#1a1a1a" },
    "syntaxString": { "dark": "grayBright", "light": "grayDark" },
    "syntaxNumber": { "dark": "redDim", "light": "redDeep" },
    "syntaxType": { "dark": "grayLight", "light": "grayDark" },
    "syntaxOperator": { "dark": "red", "light": "redDim" },
    "syntaxPunctuation": { "dark": "gray", "light": "grayDark" }
  }
}
