{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-openagent/dev/assets/oh-my-opencode.schema.json",
  "sisyphus_agent": {
    "default_builder_enabled": false,
    "planner_enabled": true,
    "replace_plan": true,
    "tdd": true
  },
  "experimental": {
    "preemptive_compaction": false,
    "dynamic_context_pruning": {
      "enabled": true,
      "notification": "detailed",
      "turn_protection": {
        "enabled": true,
        "turns": 3
      },
      "protected_tools": [
        "task",
        "background_output",
        "todowrite",
        "session_read",
        "session_search",
        "compress"
      ],
      "strategies": {
        "deduplication": {
          "enabled": true
        },
        "supersede_writes": {
          "enabled": true,
          "aggressive": false
        },
        "purge_errors": {
          "enabled": true,
          "turns": 4
        }
      }
    }
  },
  "background_task": {
    "defaultConcurrency": 4,
    "providerConcurrency": {
      "github-copilot": 3
    },
    "modelConcurrency": {
      "github-copilot/gpt-5.2": 2
    },
    "maxDepth": 4,
    "maxDescendants": 60,
    "staleTimeoutMs": 1800000,
    "messageStalenessTimeoutMs": 2700000,
    "taskTtlMs": 3600000,
    "sessionGoneTimeoutMs": 300000,
    "syncPollTimeoutMs": 60000,
    "maxToolCalls": 1500
  },
  "agents": {
    "sisyphus": {
      "model": "github-copilot/gpt-5.4",
      "variant": "high",
      "fallback_models": [
        {
          "model": "github-copilot/claude-sonnet-4.6",
          "variant": "high"
        },
        {
          "model": "github-copilot/gemini-3.1-pro-preview",
          "variant": "high"
        }
      ],
      "textVerbosity": "low",
      "prompt_append": "Caveman full. Be terse and assertive. Default to orchestration and delegation. For any non-trivial task, delegate to the appropriate agent instead of doing the work directly. Direct execution is only for clearly local trivial work or single-command checks. Prefer planning, decomposition, and verification over hands-on implementation."
    },
    "hephaestus": {
      "model": "github-copilot/gpt-5.4",
      "variant": "high"
    },
    "oracle": {
      "model": "github-copilot/gpt-5.2",
      "reasoningEffort": "high",
      "fallback_models": [
        {
          "model": "github-copilot/gpt-5.4",
          "variant": "high"
        },
        {
          "model": "github-copilot/claude-sonnet-4.6",
          "variant": "high"
        },
        {
          "model": "github-copilot/gemini-3.1-pro-preview",
          "variant": "high"
        }
      ]
    },
    "librarian": {
      "model": "github-copilot/claude-haiku-4.5"
    },
    "explore": {
      "model": "github-copilot/grok-code-fast-1",
      "fallback_models": [
        {
          "model": "github-copilot/gpt-5.4-mini"
        }
      ]
    },
    "multimodal-looker": {
      "model": "github-copilot/gpt-5.4-mini"
    },
    "prometheus": {
      "model": "github-copilot/gpt-5.2",
      "reasoningEffort": "high",
      "fallback_models": [
        {
          "model": "github-copilot/gpt-5.4",
          "variant": "high"
        },
        {
          "model": "github-copilot/claude-sonnet-4.6",
          "variant": "high"
        },
        {
          "model": "github-copilot/gemini-3.1-pro-preview",
          "variant": "high"
        }
      ]
    },
    "metis": {
      "model": "github-copilot/gpt-5.2",
      "reasoningEffort": "high",
      "fallback_models": [
        {
          "model": "github-copilot/gpt-5.4",
          "variant": "high"
        },
        {
          "model": "github-copilot/claude-sonnet-4.6",
          "variant": "high"
        }
      ]
    },
    "momus": {
      "model": "github-copilot/gpt-5.2",
      "reasoningEffort": "high",
      "fallback_models": [
        {
          "model": "github-copilot/gpt-5.4",
          "variant": "high"
        },
        {
          "model": "github-copilot/claude-sonnet-4.6",
          "variant": "high"
        },
        {
          "model": "github-copilot/gemini-3.1-pro-preview",
          "variant": "high"
        }
      ]
    },
    "atlas": {
      "model": "github-copilot/gpt-5.2",
      "reasoningEffort": "high",
      "fallback_models": [
        {
          "model": "github-copilot/gpt-5.4",
          "variant": "high"
        },
        {
          "model": "github-copilot/claude-sonnet-4.6",
          "variant": "high"
        }
      ]
    },
    "sisyphus-junior": {
      "model": "github-copilot/claude-sonnet-4.6",
      "fallback_models": [
        {
          "model": "github-copilot/gpt-5.4",
          "variant": "high"
        }
      ]
    }
  },
  "categories": {
    "visual-engineering": {
      "model": "github-copilot/gemini-3.1-pro-preview",
      "variant": "high",
      "fallback_models": [
        {
          "model": "github-copilot/gpt-5.4",
