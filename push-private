#!/usr/bin/env bash
#
# Push changes to private config files back to dotfiles-private repo
#

set -euo pipefail

PRIVATE_REPO="Raekh/dotfiles-private"
DOTFILES_DIR="${DOTFILES:-$HOME/.dotfiles}"
GH_CMD=(gh)
GIT_CMD=(git)

if [[ -n "${GITHUB_TOKEN:-}" ]]; then
    if ! gh repo view "$PRIVATE_REPO" &>/dev/null && env -u GITHUB_TOKEN gh repo view "$PRIVATE_REPO" &>/dev/null; then
        GH_CMD=(env -u GITHUB_TOKEN gh)
        GIT_CMD=(env -u GITHUB_TOKEN git)
    fi
fi

# Files to sync (paths relative to repo root)
PRIVATE_FILES=(
    "opencode/.config/opencode/opencode.jsonc"
)

# Files that live in $HOME but should be synced to a repo path
# Format: "source_in_home:dest_in_repo"
HOME_FILES=(
    ".zshrc_env:zsh/.zshrc_env"
)

usage() {
    cat <<'EOF'
Usage: push-private [options]

Options:
  -m, --message <msg>  Commit message to use
  -y, --yes            Skip interactive prompts and use all changed files
  -h, --help           Show this help
EOF
}

msg="${PUSH_PRIVATE_MESSAGE:-}"
assume_yes=false

while [[ $# -gt 0 ]]; do
    case "$1" in
        -m|--message)
            shift
            if [[ $# -eq 0 ]]; then
                echo "Error: missing value for --message" >&2
                exit 1
            fi
            msg="$1"
            ;;
        -y|--yes)
            assume_yes=true
            ;;
        -h|--help)
            usage
            exit 0
            ;;
        *)
            echo "Error: unknown option: $1" >&2
            usage >&2
            exit 1
            ;;
    esac
    shift
done

echo "Pushing private config files to $PRIVATE_REPO..."

# Check dependencies/auth
if ! command -v gh &>/dev/null; then
    echo "Error: gh is not installed or not in PATH" >&2
    exit 1
fi

if ! "${GH_CMD[@]}" auth status &>/dev/null; then
    echo "Error: Not authenticated with GitHub" >&2
    exit 1
fi

# Create temp directory for cloning
TEMP_ROOT=$(mktemp -d)
TEMP_DIR="$TEMP_ROOT/repo"
trap 'rm -rf "$TEMP_ROOT"' EXIT

# Clone the private repo
if ! "${GH_CMD[@]}" repo clone "$PRIVATE_REPO" "$TEMP_DIR" -- --quiet; then
    echo "Error: Could not clone private repo" >&2
    exit 1
fi

# Find gum binary
GUM=""
if [[ -t 0 && -t 1 ]] && command -v gum &>/dev/null; then
    GUM="gum"
elif [[ -t 0 && -t 1 ]] && [[ -x "$HOME/go/bin/gum" ]]; then
    GUM="$HOME/go/bin/gum"
fi

# Check which files have changes
changed_files=()

# Check PRIVATE_FILES (relative to DOTFILES_DIR)
for file in "${PRIVATE_FILES[@]}"; do
    src="$DOTFILES_DIR/$file"
    dest="$TEMP_DIR/$file"
    
    if [[ -f "$src" ]]; then
        if ! cmp -s "$src" "$dest" 2>/dev/null; then
            changed_files+=("$file")
            echo "  Changed: $file"
        else
            echo "  Unchanged: $file"
        fi
    else
        echo "  Warning: $file not found in dotfiles"
    fi
done

# Check HOME_FILES (source in $HOME, dest in repo)
declare -A home_file_map
for entry in "${HOME_FILES[@]}"; do
    home_path="${entry%%:*}"
    repo_path="${entry##*:}"
    home_file_map["$repo_path"]="$HOME/$home_path"
    
    src="$HOME/$home_path"
    dest="$TEMP_DIR/$repo_path"
    
    if [[ -f "$src" ]]; then
        if ! cmp -s "$src" "$dest" 2>/dev/null; then
            changed_files+=("$repo_path")
            echo "  Changed: $repo_path (from ~/$home_path)"
        else
            echo "  Unchanged: $repo_path"
        fi
    else
        echo "  Warning: ~/$home_path not found"
    fi
done

if [[ ${#changed_files[@]} -eq 0 ]]; then
    echo ""
    echo "No changes to push."
    exit 0
fi

# Let user select which files to push
selected_files=()
if [[ -n "$GUM" ]] && [[ "$assume_yes" != true ]]; then
    echo ""
    mapfile -t selected_files < <("$GUM" choose --no-limit --selected="*" "${changed_files[@]}")
    
    if [[ ${#selected_files[@]} -eq 0 ]]; then
        echo "No files selected. Aborting."
        exit 0
    fi
else
    # No gum, use all changed files
    selected_files=("${changed_files[@]}")
fi

# Copy selected files to the temp repo
echo ""
echo "Pushing selected files:"
for file in "${selected_files[@]}"; do
    # Check if it's a HOME_FILE or PRIVATE_FILE
    if [[ -n "${home_file_map[$file]:-}" ]]; then
        src="${home_file_map[$file]}"
    else
        src="$DOTFILES_DIR/$file"
    fi
    dest="$TEMP_DIR/$file"
    mkdir -p "$(dirname "$dest")"
    cp "$src" "$dest"
    echo "  → $file"
done

# Commit and push
"${GIT_CMD[@]}" -C "$TEMP_DIR" add -A

if [[ -z "$("${GIT_CMD[@]}" -C "$TEMP_DIR" status --short)" ]]; then
    echo ""
    echo "No staged changes to commit."
    exit 0
fi

# Get commit message
if [[ -z "$msg" && -n "$GUM" ]] && [[ "$assume_yes" != true ]]; then
    msg=$("$GUM" input --placeholder "Commit message (or press enter for default)")
fi

if [[ -z "$msg" ]]; then
    msg="Update private config files"
fi

if ! "${GIT_CMD[@]}" -C "$TEMP_DIR" commit -m "$msg"; then
    echo "Error: git commit failed" >&2
    exit 1
fi

if ! "${GIT_CMD[@]}" -C "$TEMP_DIR" push; then
    echo "Error: git push failed" >&2
    exit 1
fi

echo ""
echo "Private config files pushed successfully!"
